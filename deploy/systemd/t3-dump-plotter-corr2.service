[Unit]
Description=CASM T3 dump plotter (corr2)
After=network-online.target

[Service]
ExecStart=/home/casm/software/dev/casm_venvs/casm_offline_env/bin/t3-dump-plotter --archive-host casm-corr2 --archive-dir /mnt/nvme4/data/casm/t3_artifacts
Restart=always
RestartSec=5
StandardOutput=append:/home/casm/t3_dump_plotter_corr2.log
StandardError=inherit

[Install]
WantedBy=default.target
